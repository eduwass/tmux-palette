{
  "name": "tmux-palette",
  "version": "0.3.0",
  "description": "Raycast-style command palette for tmux — fast, scriptable, easy to extend",
  "bin": {
    "tmux-palette": "./bin/tmux-palette.sh"
  },
  "type": "module",
  "scripts": {
    "start": "bun src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check:dead-code": "fallow dead-code",
    "check:dupes": "fallow dupes",
    "check:format": "git ls-files -z '*.ts' '*.json' '*.jsonc' '*.yml' '*.yaml' | xargs -0 oxfmt --check",
    "format": "git ls-files -z '*.ts' '*.json' '*.jsonc' '*.yml' '*.yaml' | xargs -0 oxfmt --write"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "latest",
    "fallow": "^2.69.0",
    "oxfmt": "^0.54.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
